{
    "statementTriggers": [
        {
            "type": "Interaction",
            "class": "EntityMoved",
            "criteria": [["FromPosition", "X"], "=", 4],
            "statement": {
                "actor": {
                    "objectType": "Agent",
                    "name": ["this", ["EntityId"]],
                    "account": {
                        "homePage": "https://homepage.system.io",
                        "name": "Mr. <<[\"this\", [\"EntityId\"]]>>"
                    }
                },
                "context": {
                    "extensions":{
                        "https://yetanalytics.com/extensions/from-x": ["this", ["FromPosition", "X"]],
                        "https://yetanalytics.com/extensions/from-y": ["this", ["FromPosition", "Y"]]
                    }
                },
                "result": {
                    "response": "[<<[\"this\", [\"ToPosition\", \"X\"]]>>, <<[\"this\", [\"ToPosition\", \"Y\"]]>>]"
                }
            }
        }
    ],
    "lrs": {
        "host": "host string",
        "key": "key string",
        "secret": "secret string",
        "batch": 4
    },
    "objectCache": {
        "trackedObjects": [{"class":"*", "allAttributes": true}]
    }
}
